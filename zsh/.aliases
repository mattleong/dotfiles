# neovim
rebuild-nvim() {
  brew unlink neovim
  brew install --build-from-source --HEAD --force --fetch-HEAD neovim
}

rebuild-nvim-head() {
  brew unlink neovim
  brew install --HEAD neovim
}

rebuild-nvim-main() {
  brew unlink neovim
  brew install neovim
}

alias v='echo "Set nvim alias in .aliases.local"'

# Git shit
gl() {
	if [ $1 ] ; then
		git log --oneline -"$1" ;
	else
		git log --oneline -25
	fi
}

alias gs='git status -sb'
alias ga='git add -A'
alias gd='git diff'
alias gds='git diff --stat'
alias gca='git commit --amend'
alias gcan='git commit --amend --no-edit'
alias glg='git log --graph --abbrev-commit --decorate --format=format:"%C(bold blue)%h%C(reset) - %C(bold green)(%ar)%C(reset) %C(white)%s%C(reset) %C(dim white)- %an%C(reset)%C(bold yellow)%d%C(reset)" --all'

gc() {
	git commit -m "$1"
}

gcm() {
	emulate -L zsh
	setopt localoptions nomonitor

	local msg_file
	msg_file="$(mktemp -t codex-commit-msg.XXXXXX)" || return 1

	{
		if git diff --cached --no-ext-diff --no-textconv --quiet; then
			echo "No staged changes. Use 'ga' (or git add) first."
			return 1
		fi

		if ! git diff --cached --no-ext-diff --no-textconv --no-color >/dev/null; then
			echo "Failed to read staged diff."
			return 1
		fi

		local codex_pid codex_rc i tick locale_tag spinner_label color_prefix color_reset
		local timeout_seconds max_retries max_attempts attempt timed_out start_seconds elapsed use_spinner
		local -a spinner_frames
		codex_rc=1
		timeout_seconds=25
		max_retries=1
		max_attempts=$(( max_retries + 1 ))
		use_spinner=0

		if [[ -t 2 && "${TERM:-dumb}" != "dumb" ]]; then
			use_spinner=1
			locale_tag="${LC_ALL:-${LC_CTYPE:-$LANG}}"
			if [[ "${locale_tag:l}" == *"utf-8"* || "${locale_tag:l}" == *"utf8"* ]]; then
				spinner_frames=('⠋' '⠙' '⠹' '⠸' '⠼' '⠴' '⠦' '⠧' '⠇' '⠏')
			else
				spinner_frames=('-' '\' '|' '/')
			fi

			spinner_label="Generating commit message"
			color_prefix=$'\033[2;36m'
			color_reset=$'\033[0m'
		fi

		attempt=1
		while [ "$attempt" -le "$max_attempts" ]; do
			: >| "$msg_file"
			timed_out=0
			start_seconds=$SECONDS
			i=1
			tick=0

			{
				cat <<'EOF'
Write a git commit message from the staged diff content below.
Use only the provided content as input.
Do not run tools or shell commands.
Use Conventional Commits format.
Output only the final commit message text (no markdown, no code fences, no explanation).
Keep the subject line <= 72 characters.
Include a short body only when needed.

Full staged diff:
EOF
				git diff --cached --no-ext-diff --no-textconv --no-color
			} | codex exec \
				-m gpt-5.4-mini \
				-c 'model_reasoning_effort="low"' \
				--sandbox read-only \
				--ephemeral \
				--skip-git-repo-check \
				--color never \
				--output-last-message "$msg_file" \
				- >/dev/null 2>&1 &
			codex_pid=$!

			while kill -0 "$codex_pid" 2>/dev/null; do
				elapsed=$(( SECONDS - start_seconds ))
				if [ "$elapsed" -ge "$timeout_seconds" ]; then
					timed_out=1
					kill "$codex_pid" 2>/dev/null || true
					sleep 0.2
					if kill -0 "$codex_pid" 2>/dev/null; then
						kill -9 "$codex_pid" 2>/dev/null || true
					fi
					break
				fi

				tick=$(( tick + 1 ))
				if [ "$use_spinner" -eq 1 ] && [ "$tick" -gt 1 ]; then
					printf "\r%s%s %s%s" "$color_prefix" "${spinner_frames[i]}" "$spinner_label" "$color_reset" >&2
					i=$(( (i % ${#spinner_frames[@]}) + 1 ))
				fi
				sleep 0.1
			done

			if [ "$use_spinner" -eq 1 ] && [ "$tick" -gt 1 ]; then
				printf "\r\033[2K" >&2
			fi

			wait "$codex_pid" 2>/dev/null
			codex_rc=$?
			if [ "$timed_out" -eq 1 ]; then
				codex_rc=124
			fi

			if [ "$codex_rc" -eq 0 ] && [ -s "$msg_file" ]; then
				break
			fi

			attempt=$(( attempt + 1 ))
		done

		if [ "$codex_rc" -ne 0 ] || [ ! -s "$msg_file" ]; then
			echo "Failed after ${max_attempts} attempts (${timeout_seconds}s timeout each). Try again or run gc \"message\"."
			return 1
		fi

		git commit -F "$msg_file"
	} always {
		rm -f -- "$msg_file"
	}
}

# mcd: Makes new directory and jumps into it
mcd () { mkdir -p "$1" && cd "$1"; }

alias cd..='cd ../'                         # Go back 1 directory
# level (for fast typers)
alias ..='cd ../'                           # Go back 1 directory level
alias ...='cd ../../'                       # Go back 2 directory levels
alias .3='cd ../../../'                     # Go back 3 directory levels
alias .4='cd ../../../../'                  # Go back 4 directory levels
alias .5='cd ../../../../../'               # Go back 5 directory levels
alias .6='cd ../../../../../../'            # Go back 6 directory levels

alias edit-claude='v ~/.claude/settings.json'
alias edit-codex='v ~/.codex/config.toml'
alias edit-opencode='v ~/.config/opencode/opencode.jsonc'

alias c="codex --yolo"
alias cl="claude --allow-dangerously-skip-permissions"
